/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Cache-Control: no-store
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; script-src 'self'; worker-src 'self'; style-src 'self'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'none'

/vendor/paddleocr/*
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable

/vendor/paddleocr/worker.js
  ! Content-Security-Policy
  Content-Security-Policy: default-src 'none'; script-src 'self' blob: 'unsafe-eval' 'wasm-unsafe-eval' https://cdn.jsdelivr.net; connect-src 'self' data: https://cdn.jsdelivr.net
